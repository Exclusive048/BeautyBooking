{
  "name": "beautyhub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "npx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:validate": "npx prisma validate",
    "prisma:generate": "npx prisma generate",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "check:encoding": "node scripts/check-encoding.mjs",
    "smoke": "node scripts/smoke.mjs",
    "check": "npm run lint && npm run typecheck && npm run prisma:validate && npm run prisma:generate && npm run openapi:generate && npm run check:encoding && npm run check:mojibake && npm run smoke",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "db:reset:dev": "npx prisma migrate reset --force && npm run redis:flush:dev",
    "redis:flush:dev": "node scripts/dev-redis-flush.mjs",
    "worker:build": "npx tsc --noEmit",
    "worker": "npx --yes tsx src/worker.ts"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.18",
    "file-type": "^20.0.0",
    "lucide-react": "^0.541.0",
    "next": "^16.1.6",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.2",
    "openai": "^6.27.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "^5.10.0",
    "sharp": "^0.34.5",
    "swr": "^2.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.23",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
