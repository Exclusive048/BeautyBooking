{
  "name": "beautyhub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "npm run lint && npx tsc --noEmit && npx prisma validate && npx prisma generate && npm run check:utf8 && npm run smoke",
    "check:utf8": "node scripts/check-utf8-no-bom.mjs",
    "check:mojibake": "rg -n -F \"???\" src README.md && exit 1 || exit 0",
    "db:reset:dev": "npx prisma migrate reset --force && npm run redis:flush:dev",
    "redis:flush:dev": "node scripts/dev-redis-flush.mjs",
    "smoke": "node scripts/smoke.mjs",
    "worker:build": "npx tsc --noEmit",
    "worker": "npx --yes tsx src/worker.ts"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.1",
    "@tanstack/react-virtual": "^3.13.18",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "^5.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
