  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@index([entityType, entityId, kind, deletedAt])
  @@index([storageKey])
  @@index([createdByUserId])
  @@index([kind, visualIndexed, visualCategory])
  @@index([status, deletedAt, createdAt])
