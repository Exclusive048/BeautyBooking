generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderType {
  MASTER
  STUDIO
}

enum AccountType {
  CLIENT
  MASTER
  STUDIO
  STUDIO_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum BookingCancelledBy {
  CLIENT
  PROVIDER
  SYSTEM
}

enum ScheduleBreakKind {
  WEEKLY
  OVERRIDE
}

model UserProfile {
  id          String        @id @default(cuid())
  roles       AccountType[] @default([CLIENT])
  displayName String?
  phone       String?       @unique
  email       String?       @unique

  // NEW (optional profile fields)
  firstName   String?
  lastName    String?
  middleName  String?
  birthDate   DateTime?
  address     String?
  geoLat      Float?
  geoLng      Float?

  providers   Provider[]    @relation("ProviderOwner")
  bookings    Booking[]     @relation("BookingClient")

  telegram    TelegramLink?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TelegramLink {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone     String   @unique
  chatId    String   @unique
  username  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([chatId])
}

model OtpCode {
  id         String   @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  usedAt     DateTime?

  createdAt  DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

model Provider {
  id             String        @id @default(cuid())
  type           ProviderType
  name           String
  tagline        String
  rating         Float         @default(0)
  reviews        Int           @default(0)
  priceFrom      Int           @default(0)
  address        String
  district       String
  categories     String[]      @default([])
  availableToday Boolean       @default(false)
  timezone       String        @default("Asia/Almaty")
  bufferBetweenBookingsMin Int @default(0)

  studioId       String?
  studio         Provider?     @relation("StudioMasters", fields: [studioId], references: [id], onDelete: SetNull)
  masters        Provider[]    @relation("StudioMasters")

  // NEW (optional business contact + publish + geo)
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  description    String?
  avatarUrl      String?
  geoLat         Float?
  geoLng         Float?
  isPublished    Boolean       @default(false)
  
  ownerUserId    String?
  owner          UserProfile?  @relation("ProviderOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  services       Service[]
  masterServices MasterService[] @relation("MasterServices")
  bookings       Booking[]
  masterBookings Booking[]     @relation("BookingMaster")
  weeklySchedule WeeklySchedule[]
  scheduleOverrides ScheduleOverride[]
  scheduleBlocks ScheduleBlock[]
  scheduleBreaks ScheduleBreak[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([ownerUserId])
  @@index([studioId])
}

model Service {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  name        String
  durationMin Int
  price       Int

  bookings    Booking[]
  masterServices MasterService[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([providerId])
}

model MasterService {
  id                 String   @id @default(cuid())
  masterProviderId   String
  masterProvider     Provider @relation("MasterServices", fields: [masterProviderId], references: [id], onDelete: Cascade)
  serviceId          String
  service            Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  priceOverride      Int?
  durationOverrideMin Int?
  isEnabled          Boolean  @default(true)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([masterProviderId, serviceId])
  @@index([masterProviderId])
  @@index([serviceId])
}

model Booking {
  id           String        @id @default(cuid())
  providerId   String
  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)

  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  masterProviderId String?
  masterProvider   Provider?   @relation("BookingMaster", fields: [masterProviderId], references: [id], onDelete: SetNull)

  clientUserId String?
  clientUser   UserProfile?  @relation("BookingClient", fields: [clientUserId], references: [id], onDelete: SetNull)

  startAtUtc   DateTime?
  endAtUtc     DateTime?

  slotLabel    String
  clientName   String
  clientPhone  String
  comment      String?

  status       BookingStatus @default(PENDING)
  cancelledBy  BookingCancelledBy?
  cancelReason String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([providerId])
  @@index([masterProviderId])
  @@index([startAtUtc])
  @@index([serviceId])
  @@index([clientUserId])
}

model WeeklySchedule {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  dayOfWeek  Int
  startLocal String
  endLocal   String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, dayOfWeek])
}

model ScheduleOverride {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  date       DateTime
  isDayOff   Boolean  @default(false)
  startLocal String?
  endLocal   String?
  reason     String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, date])
}

model ScheduleBlock {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  date       DateTime
  startLocal String
  endLocal   String
  reason     String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, date])
}

model ScheduleBreak {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  kind       ScheduleBreakKind
  dayOfWeek  Int?
  date       DateTime?
  startLocal String
  endLocal   String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, kind])
  @@index([providerId, kind, dayOfWeek])
  @@index([providerId, date])
}
