generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

  url = env("DATABASE_URL")
}

enum ProviderType {
  MASTER

  STUDIO
}

enum SubscriptionScope {
  MASTER

  STUDIO
}

enum StudioRole {
  OWNER

  ADMIN

  MASTER
}

enum MembershipStatus {
  ACTIVE

  PENDING

  REJECTED

  LEFT
}

enum AccountType {
  CLIENT

  MASTER

  STUDIO

  STUDIO_ADMIN

  ADMIN

  SUPERADMIN
}

enum PlanTier {
  FREE

  PRO

  PREMIUM
}

enum ConsentType {
  TERMS

  PRIVACY

  MARKETING

  PUBLIC_PROFILE
}

enum BookingStatus {
  NEW

  PENDING

  CONFIRMED

  CHANGE_REQUESTED

  REJECTED

  IN_PROGRESS

  PREPAID

  STARTED

  FINISHED

  CANCELLED

  NO_SHOW
}

enum ChatSenderType {
  CLIENT

  MASTER
}

enum BookingCancelledBy {
  CLIENT

  PROVIDER

  SYSTEM
}

enum BookingRequestedBy {
  CLIENT

  MASTER
}

enum BookingActionRequiredBy {
  CLIENT

  MASTER
}

enum DiscountType {
  PERCENT

  FIXED
}

enum DiscountApplyMode {
  ALL_SERVICES

  PRICE_FROM

  MANUAL
}

enum ScheduleBreakKind {
  WEEKLY

  OVERRIDE
}

enum ScheduleRuleKind {
  WEEKLY

  CYCLE
}

enum ScheduleOverrideKind {
  OFF

  TIME_RANGE

  TEMPLATE
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CANCELLED
  BOOKING_CANCELLED_BY_MASTER
  BOOKING_CANCELLED_BY_CLIENT
  BOOKING_RESCHEDULED
  BOOKING_RESCHEDULE_REQUESTED
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_DECLINED
  BOOKING_REJECTED
  BOOKING_REMINDER_24H
  BOOKING_REMINDER_2H
  BOOKING_COMPLETED_REVIEW
  BOOKING_NO_SHOW
  REVIEW_LEFT
  REVIEW_REPLIED
  STUDIO_INVITE_RECEIVED
  STUDIO_INVITE_ACCEPTED
  STUDIO_INVITE_REJECTED
  STUDIO_MEMBER_LEFT
  STUDIO_SCHEDULE_REQUEST
  STUDIO_SCHEDULE_APPROVED
  STUDIO_SCHEDULE_REJECTED
  STUDIO_DISBANDED
  MASTER_CABINET_DELETED
  MODEL_NEW_APPLICATION
  MODEL_APPLICATION_RECEIVED
  MODEL_APPLICATION_REJECTED
  MODEL_TIME_PROPOSED
  MODEL_BOOKING_CREATED
  MODEL_TIME_CONFIRMED
  HOT_SLOT_AVAILABLE
  HOT_SLOT_PUBLISHED
  HOT_SLOT_BOOKED
  HOT_SLOT_EXPIRING
  BILLING_PAYMENT_SUCCEEDED
  BILLING_PAYMENT_FAILED
  BILLING_RENEWAL_CONFIRMATION_REQUIRED
  BILLING_SUBSCRIPTION_CANCELLED
  BILLING_SUBSCRIPTION_EXPIRED
  CHAT_MESSAGE_RECEIVED
  CATEGORY_APPROVED
  CATEGORY_REJECTED
}

enum MediaEntityType {
  USER

  MASTER

  STUDIO

  SITE

  MODEL_APPLICATION

  CLIENT_CARD

  BOOKING
}

enum MediaKind {
  AVATAR

  PORTFOLIO

  MODEL_APPLICATION_PHOTO

  CLIENT_CARD_PHOTO

  BOOKING_REFERENCE
}

enum MediaAssetStatus {
  PENDING

  READY

  BROKEN
}

enum StudioMemberRole {
  OWNER

  ADMIN

  MASTER

  FINANCE
}

enum StudioMemberStatus {
  ACTIVE

  INVITED

  DISABLED
}

enum SubscriptionStatus {
  ACTIVE

  PENDING

  PAST_DUE

  CANCELLED

  EXPIRED
}

enum BillingPaymentStatus {
  PENDING

  SUCCEEDED

  CANCELED

  FAILED

  REFUNDED
}

enum BookingSource {
  MANUAL

  WEB

  APP
}

enum TimeBlockType {
  BREAK

  BLOCK
}

enum WorkExceptionType {
  OFF

  SHIFT
}

enum ScheduleChangeRequestStatus {
  PENDING

  APPROVED

  REJECTED
}

enum ReviewTargetType {
  provider

  studio
}

enum ReviewTagType {
  PUBLIC

  PRIVATE
}

enum ModelOfferStatus {
  ACTIVE

  CLOSED

  ARCHIVED
}

enum ModelApplicationStatus {
  PENDING

  REJECTED

  APPROVED_WAITING_CLIENT

  CONFIRMED
}

enum CategoryStatus {
  PENDING

  APPROVED

  REJECTED
}

model UserProfile {
  id String @id @default(cuid())

  roles AccountType[] @default([CLIENT])

  displayName String?

  phone String? @unique

  email String? @unique

  telegramId String? @unique

  telegramUsername String?

  externalPhotoUrl String?
  avatarFocalX     Float?
  avatarFocalY     Float?

  telegramLink TelegramLink?

  telegramLinkTokens TelegramLinkToken[]

  vkLink VkLink?

  createdCategories GlobalCategory[] @relation("GlobalCategoryCreator")

  subscriptions        UserSubscription[]
  hotSlotSubscriptions HotSlotSubscription[]

  // NEW (optional profile fields)

  firstName String?

  lastName String?

  middleName String?

  birthDate DateTime?

  address String?

  geoLat Float?

  geoLng Float?

  publicUsername String? @unique

  publicUsernameUpdatedAt DateTime?

  providers Provider[] @relation("ProviderOwner")

  ownedStudios Studio[] @relation("StudioOwner")

  masterProfile MasterProfile?

  studioMemberships StudioMembership[]

  studioMembers StudioMember[]

  studioInvites StudioInvite[] @relation("StudioInvitedBy")

  bookings Booking[] @relation("BookingClient")

  notifications     Notification[]
  pushSubscriptions PushSubscription[]

  consents UserConsent[]

  mediaAssetsCreated MediaAsset[] @relation("MediaAssetCreatedBy")

  reviewsAuthored Review[] @relation("ReviewAuthor")

  favorites Favorite[]

  modelApplications ModelApplication[]

  clientNotes ClientNote[] @relation("ClientNotesForClient")
  clientCards ClientCard[] @relation("ClientCardsForUser")

  publicUsernameAliases PublicUsernameAlias[] @relation("ClientPublicUsernameAliases")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
}

model UserConsent {
  id String @id @default(cuid())

  userId String

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  consentType ConsentType

  documentVersion String

  agreedAt DateTime @default(now())

  ipAddress String?

  userAgent String?

  revokedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([userId, consentType])
  @@index([userId])
}

model Studio {
  id String @id @default(cuid())

  providerId String @unique

  provider Provider @relation("StudioProvider", fields: [providerId], references: [id], onDelete: Cascade)

  ownerUserId String?

  owner UserProfile? @relation("StudioOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  memberships StudioMembership[]

  studioMembers StudioMember[]

  invites StudioInvite[]

  ratingAvg Float @default(0)

  ratingCount Int @default(0)

  serviceCategories ServiceCategory[]

  masterServices MasterService[]

  workShiftTemplates WorkShiftTemplate[]

  workDayRules WorkDayRule[]

  workExceptions WorkException[]

  timeBlocks TimeBlock[]

  scheduleRequests ScheduleChangeRequest[]

  services Service[]

  bookings Booking[]

  bookingServiceItems BookingServiceItem[]

  portfolioItems PortfolioItem[]

  reviews Review[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model MasterProfile {
  id String @id @default(cuid())

  userId String @unique

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  providerId String @unique

  provider Provider @relation("MasterProvider", fields: [providerId], references: [id], onDelete: Cascade)

  lastBookingsSeenAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model StudioMembership {
  id String @id @default(cuid())

  userId String

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  studioId String

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  roles StudioRole[]

  status MembershipStatus @default(PENDING)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([userId, studioId])
  @@index([userId])
  @@index([studioId])
  @@index([status])
}

model StudioInvite {
  id String @id @default(cuid())

  studioId String

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  phone String

  status MembershipStatus @default(PENDING)

  invitedByUserId String

  invitedBy UserProfile @relation("StudioInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([studioId, phone])
  @@index([studioId])
  @@index([phone])
  @@index([status])
}

model OtpCode {
  id String @id @default(cuid())

  phone String

  codeHash String

  expiresAt DateTime

  usedAt DateTime?

  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

model Provider {
  id String @id @default(cuid())

  type ProviderType

  name String

  tagline String

  rating Float @default(0)

  reviews Int @default(0)

  ratingAvg Float @default(0)

  ratingCount Int @default(0)

  priceFrom Int @default(0)

  address String

  district String

  categories String[] @default([])

  availableToday Boolean @default(false)

  timezone String @default("Asia/Almaty")

  bufferBetweenBookingsMin Int @default(0)

  autoConfirmBookings       Boolean @default(false)
  cancellationDeadlineHours Int?
  remindersEnabled          Boolean @default(true)

  studioId String?

  studio Provider? @relation("StudioMasters", fields: [studioId], references: [id], onDelete: SetNull)

  masters Provider[] @relation("StudioMasters")

  // NEW (optional business contact + publish + geo)

  contactName String?

  contactPhone String?

  contactEmail String?

  description String?

  avatarUrl    String?
  avatarFocalX Float?
  avatarFocalY Float?
  bannerFocalX Float?
  bannerFocalY Float?

  geoLat Float?

  geoLng Float?

  isPublished Boolean @default(false)

  publicUsername String? @unique

  publicUsernameUpdatedAt DateTime?

  ownerUserId String?

  owner UserProfile? @relation("ProviderOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  services Service[]

  masterServices MasterService[] @relation("MasterServices")

  bookings Booking[]

  masterBookings Booking[] @relation("BookingMaster")

  weeklySchedule WeeklySchedule[]

  scheduleRules ScheduleRule[]

  scheduleOverrides ScheduleOverride[]

  scheduleBlocks ScheduleBlock[]

  scheduleBreaks ScheduleBreak[]

  scheduleTemplates ScheduleTemplate[]

  weeklyScheduleConfig WeeklyScheduleConfig?

  scheduleChangeRequests ScheduleChangeRequest[]

  discountRule DiscountRule?

  hotSlots             HotSlot[]
  hotSlotSubscriptions HotSlotSubscription[]

  studioProfile Studio? @relation("StudioProvider")

  masterProfile MasterProfile? @relation("MasterProvider")

  reviewsAbout Review[]

  portfolioItems PortfolioItem[]

  publicUsernameAliases PublicUsernameAlias[]

  createdGlobalCategories GlobalCategory[] @relation("GlobalCategoryCreatorProvider")

  modelOffers ModelOffer[]

  clientNotes ClientNote[] @relation("ClientNotesForMaster")

  clientCards ClientCard[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([studioId])
}

model PublicUsernameAlias {
  id String @id @default(cuid())

  username String @unique

  providerId String?

  provider Provider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  clientUserId String?

  clientUser UserProfile? @relation("ClientPublicUsernameAliases", fields: [clientUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([providerId])
  @@index([clientUserId])
}

model ClientCard {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  clientUserId String?

  clientUser UserProfile? @relation("ClientCardsForUser", fields: [clientUserId], references: [id], onDelete: SetNull)

  clientPhone String?

  notes String? @db.Text

  tags String[] @default([])

  photos ClientCardPhoto[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, clientUserId])
  @@index([providerId, clientPhone])
  @@index([clientUserId])
  @@index([clientPhone])
}

model ClientCardPhoto {
  id String @id @default(cuid())

  cardId String

  card ClientCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  mediaAssetId String @unique

  mediaAsset MediaAsset @relation("ClientCardPhotoAsset", fields: [mediaAssetId], references: [id], onDelete: Cascade)

  caption String?

  createdAt DateTime @default(now())

  @@index([cardId])
}

model Service {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  studioId String?

  studio Studio? @relation(fields: [studioId], references: [id], onDelete: SetNull)

  categoryId String?

  category ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  globalCategoryId String?

  globalCategory GlobalCategory? @relation(fields: [globalCategoryId], references: [id], onDelete: SetNull)

  name String

  title String?

  description String?

  durationMin Int

  price Int

  baseDurationMin Int?

  basePrice Int?

  sortOrder Int @default(0)

  isEnabled Boolean @default(true)

  isActive Boolean @default(true)

  onlinePaymentEnabled Boolean @default(false)

  requiresReferencePhoto Boolean @default(false)

  bookingQuestions ServiceBookingQuestion[]

  bookings Booking[]

  masterServices MasterService[]

  portfolioItems PortfolioItemService[]

  bookingItems BookingServiceItem[]

  hotSlots HotSlot[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([providerId])
}

model ServiceBookingQuestion {
  id        String  @id @default(cuid())
  serviceId String
  text      String
  required  Boolean @default(false)
  order     Int     @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model MasterService {
  id String @id @default(cuid())

  masterProviderId String

  masterProvider Provider @relation("MasterServices", fields: [masterProviderId], references: [id], onDelete: Cascade)

  studioId String?

  studio Studio? @relation(fields: [studioId], references: [id], onDelete: SetNull)

  masterId String?

  serviceId String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  modelOffers ModelOffer[]

  priceOverride Int?

  durationOverrideMin Int?

  isEnabled Boolean @default(true)

  commissionPct Float?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([masterProviderId, serviceId])
  @@index([masterProviderId])
  @@index([serviceId])
}

model DiscountRule {
  id String @id @default(cuid())

  providerId String @unique

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  isEnabled Boolean @default(false)

  triggerHours Int

  discountType DiscountType

  discountValue Int

  applyMode DiscountApplyMode

  minPriceFrom Int?

  serviceIds String[] @default([])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model HotSlot {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  serviceId String?

  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  startAtUtc DateTime

  endAtUtc DateTime

  discountType DiscountType

  discountValue Int

  isActive Boolean @default(true)

  activatedAt DateTime @default(now())

  expiresAtUtc DateTime

  reason String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([providerId, startAtUtc, endAtUtc])
  @@index([providerId, startAtUtc])
  @@index([isActive, expiresAtUtc])
  @@index([providerId, isActive])
}

model HotSlotSubscription {
  id String @id @default(cuid())

  userId     String
  providerId String

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, providerId])
  @@index([providerId])
  @@index([userId])
}

model Booking {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  serviceId String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  masterProviderId String?

  masterProvider Provider? @relation("BookingMaster", fields: [masterProviderId], references: [id], onDelete: SetNull)

  clientUserId String?

  clientUser UserProfile? @relation("BookingClient", fields: [clientUserId], references: [id], onDelete: SetNull)

  // UTC instants only. Use these for all scheduling logic and UI formatting.

  startAtUtc DateTime?

  endAtUtc DateTime?

  studioId String?

  studio Studio? @relation(fields: [studioId], references: [id], onDelete: SetNull)

  masterId String?

  clientId String?

  // Legacy fields (deprecated). Do not use for formatting or logic.

  startAt DateTime?

  endAt DateTime?

  slotLabel String

  clientName String

  clientPhone String

  clientNameSnapshot String?

  clientPhoneSnapshot String?

  comment String?

  source BookingSource @default(MANUAL)

  notes String?

  silentMode Boolean @default(false)

  referencePhotoAssetId String?

  bookingAnswers Json?

  referencePhoto MediaAsset? @relation("BookingReferencePhoto", fields: [referencePhotoAssetId], references: [id])

  status BookingStatus @default(PENDING)

  cancelledBy BookingCancelledBy?

  cancelReason String?

  cancelledAtUtc DateTime?

  proposedStartAt DateTime?

  proposedEndAt DateTime?

  requestedBy BookingRequestedBy?

  changeComment String?

  actionRequiredBy BookingActionRequiredBy?

  clientChangeRequestsCount Int @default(0)

  masterChangeRequestsCount Int @default(0)

  reminder24hSentAt DateTime?
  reminder2hSentAt  DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  notifications Notification[]

  chat BookingChat?

  review Review?

  serviceItems BookingServiceItem[]

  modelApplication ModelApplication? @relation("ModelApplicationBooking")

  @@index([providerId, startAtUtc, endAtUtc])
  @@index([providerId])
  @@index([masterProviderId])
  @@index([startAtUtc])
  @@index([serviceId])
  @@index([clientUserId])
  @@index([studioId])
  @@index([masterId])
  @@index([status, startAtUtc])
}

model BookingChat {
  id String @id @default(cuid())

  bookingId String @unique

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  messages ChatMessage[]

  createdAt DateTime @default(now())

  @@index([bookingId])
}

model ChatMessage {
  id String @id @default(cuid())

  chatId String

  chat BookingChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  senderType ChatSenderType

  senderName String

  body String @db.Text

  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
  @@index([chatId, readAt])
}

model Notification {
  id String @id @default(cuid())

  userId String

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  type NotificationType

  title String

  body String

  payloadJson Json

  isRead Boolean @default(false)

  bookingId String?

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([bookingId])
}

model PushSubscription {
  id        String      @id @default(cuid())
  userId    String
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String      @unique
  p256dh    String
  auth      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

model WeeklySchedule {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  dayOfWeek Int

  startLocal String

  endLocal String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, dayOfWeek])
}

model ScheduleRule {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  kind ScheduleRuleKind

  timezone String

  anchorDate DateTime?

  payloadJson Json

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([providerId, isActive])
  @@index([providerId, updatedAt])
}

model ScheduleOverride {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  date DateTime

  kind ScheduleOverrideKind @default(TIME_RANGE)

  isDayOff Boolean @default(false)

  startLocal String?

  endLocal String?

  templateId String?

  template ScheduleTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  isActive Boolean?

  note String?

  reason String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, date])
}

model ScheduleBlock {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  date DateTime

  startLocal String

  endLocal String

  reason String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, date])
}

model ScheduleBreak {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  kind ScheduleBreakKind

  dayOfWeek Int?

  date DateTime?

  startLocal String

  endLocal String

  note String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, kind])
  @@index([providerId, kind, dayOfWeek])
  @@index([providerId, date])
}

model ScheduleTemplate {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  name String

  startLocal String

  endLocal String

  color String?

  breaks ScheduleTemplateBreak[]

  scheduleOverrides ScheduleOverride[]

  weeklyScheduleDays WeeklyScheduleDay[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([providerId, name])
  @@index([providerId])
}

model ScheduleTemplateBreak {
  id String @id @default(cuid())

  templateId String

  template ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  startLocal String

  endLocal String

  sortOrder Int @default(0)

  @@index([templateId])
}

model WeeklyScheduleConfig {
  id String @id @default(cuid())

  providerId String @unique

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  days WeeklyScheduleDay[]

  updatedAt DateTime @updatedAt

  createdAt DateTime @default(now())
}

model WeeklyScheduleDay {
  id String @id @default(cuid())

  configId String

  config WeeklyScheduleConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  weekday Int

  templateId String?

  template ScheduleTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  isActive Boolean @default(false)

  @@unique([configId, weekday])
  @@index([templateId])
}

model TelegramLink {
  id String @id @default(cuid())

  userId String @unique

  telegramUserId String?

  chatId String? @unique

  isEnabled Boolean @default(true)

  linkedAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VkLink {
  id String @id @default(cuid())

  userId String @unique

  vkUserId String @unique

  accessToken String

  refreshToken String

  deviceId String

  isEnabled Boolean @default(true)

  linkedAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TelegramLinkToken {
  id String @id @default(cuid())

  userId String

  tokenHash String @unique

  expiresAt DateTime

  usedAt DateTime?

  createdAt DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MediaAsset {
  id String @id @default(cuid())

  entityType MediaEntityType

  entityId String

  kind MediaKind

  storageProvider String

  storageKey String

  mimeType String

  sizeBytes Int

  originalFilename    String
  focalX              Float?
  focalY              Float?
  visualIndexed       Boolean   @default(false)
  visualIndexedAt     DateTime?
  visualPromptVersion String?
  visualDescription   String?
  visualMeta          Json?
  visualCategory      String?
