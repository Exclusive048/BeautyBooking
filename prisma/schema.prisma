generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderType {
  MASTER
  STUDIO
}

enum AccountType {
  CLIENT
  MASTER
  STUDIO
  STUDIO_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model UserProfile {
  id          String        @id @default(cuid())
  roles       AccountType[] @default([CLIENT])
  displayName String?
  phone       String?       @unique
  email       String?       @unique

  // NEW (optional profile fields)
  firstName   String?
  lastName    String?
  middleName  String?
  birthDate   DateTime?
  address     String?
  geoLat      Float?
  geoLng      Float?

  providers   Provider[]    @relation("ProviderOwner")
  bookings    Booking[]     @relation("BookingClient")

  telegram    TelegramLink?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TelegramLink {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone     String   @unique
  chatId    String   @unique
  username  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([chatId])
}

model OtpCode {
  id         String   @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  usedAt     DateTime?

  createdAt  DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

model Provider {
  id             String        @id @default(cuid())
  type           ProviderType
  name           String
  tagline        String
  rating         Float         @default(0)
  reviews        Int           @default(0)
  priceFrom      Int           @default(0)
  address        String
  district       String
  categories     String[]      @default([])
  availableToday Boolean       @default(false)

  // NEW (optional business contact + publish + geo)
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  description    String?
  avatarUrl      String?
  geoLat         Float?
  geoLng         Float?
  isPublished    Boolean       @default(false)
  
  ownerUserId    String?
  owner          UserProfile?  @relation("ProviderOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  services       Service[]
  bookings       Booking[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([ownerUserId])
}

model Service {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  name        String
  durationMin Int
  price       Int

  bookings    Booking[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([providerId])
}

model Booking {
  id           String        @id @default(cuid())
  providerId   String
  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)

  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  clientUserId String?
  clientUser   UserProfile?  @relation("BookingClient", fields: [clientUserId], references: [id], onDelete: SetNull)

  slotLabel    String
  clientName   String
  clientPhone  String
  comment      String?

  status       BookingStatus @default(PENDING)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([providerId])
  @@index([serviceId])
  @@index([clientUserId])
}
