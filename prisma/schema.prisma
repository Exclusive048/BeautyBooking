generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderType {
  MASTER
  STUDIO
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Provider {
  id            String       @id @default(cuid())
  type          ProviderType
  name          String
  tagline       String
  rating        Float        @default(0)
  reviews       Int          @default(0)
  priceFrom     Int          @default(0)
  address       String
  district      String
  categories    String[]     @default([])
  availableToday Boolean     @default(false)

  services      Service[]
  bookings      Booking[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  name        String
  durationMin Int
  price       Int

  bookings    Booking[] 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id          String        @id @default(cuid())
  providerId  String
  provider    Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)

  serviceId   String
  service     Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  slotLabel   String
  clientName  String
  clientPhone String
  comment     String?

  status      BookingStatus @default(PENDING)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([providerId])
  @@index([serviceId])
}
