generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderType {
  MASTER
  STUDIO
}

enum StudioRole {
  OWNER
  ADMIN
  MASTER
}

enum MembershipStatus {
  ACTIVE
  PENDING
  REJECTED
  LEFT
}

enum AccountType {
  CLIENT
  MASTER
  STUDIO
  STUDIO_ADMIN
  ADMIN
  SUPERADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum BookingCancelledBy {
  CLIENT
  PROVIDER
  SYSTEM
}

enum ScheduleBreakKind {
  WEEKLY
  OVERRIDE
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
}

model UserProfile {
  id          String        @id @default(cuid())
  roles       AccountType[] @default([CLIENT])
  displayName String?
  phone       String?       @unique
  email       String?       @unique
  telegramId  String?       @unique
  telegramUsername String?

  // NEW (optional profile fields)
  firstName   String?
  lastName    String?
  middleName  String?
  birthDate   DateTime?
  address     String?
  geoLat      Float?
  geoLng      Float?

  providers   Provider[]    @relation("ProviderOwner")
  ownedStudios Studio[]     @relation("StudioOwner")
  masterProfile MasterProfile?
  studioMemberships StudioMembership[]
  studioInvites StudioInvite[] @relation("StudioInvitedBy")
  bookings    Booking[]     @relation("BookingClient")
  notifications Notification[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Studio {
  id          String             @id @default(cuid())
  providerId  String             @unique
  provider    Provider           @relation("StudioProvider", fields: [providerId], references: [id], onDelete: Cascade)
  ownerUserId String?
  owner       UserProfile?       @relation("StudioOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  memberships StudioMembership[]
  invites     StudioInvite[]

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model MasterProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId  String    @unique
  provider    Provider  @relation("MasterProvider", fields: [providerId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model StudioMembership {
  id        String           @id @default(cuid())
  userId    String
  user      UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studioId  String
  studio    Studio           @relation(fields: [studioId], references: [id], onDelete: Cascade)
  roles     StudioRole[]
  status    MembershipStatus @default(PENDING)

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([studioId])
  @@index([status])
  @@unique([userId, studioId])
}

model StudioInvite {
  id              String           @id @default(cuid())
  studioId        String
  studio          Studio           @relation(fields: [studioId], references: [id], onDelete: Cascade)
  phone           String
  status          MembershipStatus @default(PENDING)
  invitedByUserId String
  invitedBy       UserProfile      @relation("StudioInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([studioId])
  @@index([phone])
  @@index([status])
  @@unique([studioId, phone])
}

model OtpCode {
  id         String   @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  usedAt     DateTime?

  createdAt  DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

model Provider {
  id             String        @id @default(cuid())
  type           ProviderType
  name           String
  tagline        String
  rating         Float         @default(0)
  reviews        Int           @default(0)
  priceFrom      Int           @default(0)
  address        String
  district       String
  categories     String[]      @default([])
  availableToday Boolean       @default(false)
  timezone       String        @default("Asia/Almaty")
  bufferBetweenBookingsMin Int @default(0)

  studioId       String?
  studio         Provider?     @relation("StudioMasters", fields: [studioId], references: [id], onDelete: SetNull)
  masters        Provider[]    @relation("StudioMasters")

  // NEW (optional business contact + publish + geo)
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  description    String?
  avatarUrl      String?
  geoLat         Float?
  geoLng         Float?
  isPublished    Boolean       @default(false)
  
  ownerUserId    String?
  owner          UserProfile?  @relation("ProviderOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  services       Service[]
  masterServices MasterService[] @relation("MasterServices")
  bookings       Booking[]
  masterBookings Booking[]     @relation("BookingMaster")
  weeklySchedule WeeklySchedule[]
  scheduleOverrides ScheduleOverride[]
  scheduleBlocks ScheduleBlock[]
  scheduleBreaks ScheduleBreak[]

  studioProfile Studio?       @relation("StudioProvider")
  masterProfile MasterProfile? @relation("MasterProvider")

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([ownerUserId])
  @@index([studioId])
}

model Service {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  name        String
  durationMin Int
  price       Int
  isEnabled   Boolean  @default(true)

  bookings    Booking[]
  masterServices MasterService[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([providerId])
}

model MasterService {
  id                 String   @id @default(cuid())
  masterProviderId   String
  masterProvider     Provider @relation("MasterServices", fields: [masterProviderId], references: [id], onDelete: Cascade)
  serviceId          String
  service            Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  priceOverride      Int?
  durationOverrideMin Int?
  isEnabled          Boolean  @default(true)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([masterProviderId, serviceId])
  @@index([masterProviderId])
  @@index([serviceId])
}

model Booking {
  id           String        @id @default(cuid())
  providerId   String
  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)

  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  masterProviderId String?
  masterProvider   Provider?   @relation("BookingMaster", fields: [masterProviderId], references: [id], onDelete: SetNull)

  clientUserId String?
  clientUser   UserProfile?  @relation("BookingClient", fields: [clientUserId], references: [id], onDelete: SetNull)

  startAtUtc   DateTime?
  endAtUtc     DateTime?

  slotLabel    String
  clientName   String
  clientPhone  String
  comment      String?

  status       BookingStatus @default(PENDING)
  cancelledBy  BookingCancelledBy?
  cancelReason String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  notifications Notification[]

  @@index([providerId])
  @@index([masterProviderId])
  @@index([startAtUtc])
  @@index([serviceId])
  @@index([clientUserId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  body      String?
  bookingId String?
  booking   Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  readAt    DateTime?

  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([bookingId])
}

model WeeklySchedule {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  dayOfWeek  Int
  startLocal String
  endLocal   String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, dayOfWeek])
}

model ScheduleOverride {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  date       DateTime
  isDayOff   Boolean  @default(false)
  startLocal String?
  endLocal   String?
  reason     String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, date])
}

model ScheduleBlock {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  date       DateTime
  startLocal String
  endLocal   String
  reason     String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, date])
}

model ScheduleBreak {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  kind       ScheduleBreakKind
  dayOfWeek  Int?
  date       DateTime?
  startLocal String
  endLocal   String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, kind])
  @@index([providerId, kind, dayOfWeek])
  @@index([providerId, date])
}
