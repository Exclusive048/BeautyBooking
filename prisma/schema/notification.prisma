// === DOMAIN: Notification ===

model Notification {
  id String @id @default(cuid())

  userId String

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  type NotificationType

  title String

  body String

  payloadJson Json

  isRead Boolean @default(false)

  bookingId String?

  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  readAt DateTime?

  // Soft-delete marker. Once set, all read paths (badge count, list,
  // mark-all-read) filter the row out so it vanishes from the user's
  // surface — but the row persists for audit/restoration until a future
  // cleanup job purges old soft-deletes. `null` = active.
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([userId, deletedAt, createdAt])
  @@index([bookingId])
}

model PushSubscription {
  id        String      @id @default(cuid())
  userId    String
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String      @unique
  p256dh    String
  auth      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}
