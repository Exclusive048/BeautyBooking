// === DOMAIN: Service / Catalog ===

model Service {
  id String @id @default(cuid())

  providerId String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  studioId String?

  studio Studio? @relation(fields: [studioId], references: [id], onDelete: SetNull)

  categoryId String?

  category ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  globalCategoryId String?

  globalCategory GlobalCategory? @relation(fields: [globalCategoryId], references: [id], onDelete: SetNull)

  name String

  title String?

  description String?

  durationMin Int

  price Int

  baseDurationMin Int?

  basePrice Int?

  sortOrder Int @default(0)

  isEnabled Boolean @default(true)

  isActive Boolean @default(true)

  onlinePaymentEnabled Boolean @default(false)

  requiresReferencePhoto Boolean @default(false)

  bookingQuestions ServiceBookingQuestion[]

  bookings Booking[]

  masterServices MasterService[]

  modelOffers ModelOffer[]

  portfolioItems PortfolioItemService[]

  bookingItems BookingServiceItem[]

  hotSlots HotSlot[]

  packageItems ServicePackageItem[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([providerId, isEnabled, isActive])
  @@index([globalCategoryId, isEnabled, isActive])
}

model ServiceBookingQuestion {
  id        String  @id @default(cuid())
  serviceId String
  text      String
  required  Boolean @default(false)
  order     Int     @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model MasterService {
  id String @id @default(cuid())

  masterProviderId String

  masterProvider Provider @relation("MasterServices", fields: [masterProviderId], references: [id], onDelete: Cascade)

  studioId String?

  studio Studio? @relation(fields: [studioId], references: [id], onDelete: SetNull)

  masterId String?

  serviceId String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  modelOffers ModelOffer[]

  priceOverride Int?

  durationOverrideMin Int?

  isEnabled Boolean @default(true)

  commissionPct Float?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([masterProviderId, serviceId])
  @@index([masterProviderId])
  @@index([serviceId])
  @@index([masterProviderId, isEnabled])
  @@index([serviceId, isEnabled])
}

model ServiceCategory {
  id String @id @default(cuid())

  studioId String

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  title String

  sortOrder Int @default(0)

  services Service[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([studioId, sortOrder])
}

model GlobalCategory {
  id String @id @default(cuid())

  name String

  slug String @unique

  icon String?

  parentId         String?          @map("parent_id")
  parent           GlobalCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children         GlobalCategory[] @relation("CategoryHierarchy")
  orderIndex       Int              @default(0)
  status           CategoryStatus   @default(PENDING)
  proposedBy       String?
  proposedAt       DateTime?
  context          String?
  reviewedAt       DateTime?
  isSystem         Boolean          @default(false)
  visibleToAll     Boolean          @default(true)
  visualSearchSlug String?          @unique

  usageCount Int @default(0)

  createdByUserId String?

  createdBy UserProfile? @relation("GlobalCategoryCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdByProviderId String?

  createdByProvider Provider? @relation("GlobalCategoryCreatorProvider", fields: [createdByProviderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  services Service[]

  tags Tag[]

  portfolioItems PortfolioItem[]

  @@index([status])
  @@index([parentId, orderIndex])
  @@index([isSystem])
  @@index([visibleToAll])
  @@index([createdByUserId])
  @@index([createdByProviderId])
  @@index([status, visibleToAll, isSystem, name])
}

model Tag {
  id String @id @default(cuid())

  name String

  slug String @unique

  usageCount Int @default(0)

  isFeatured Boolean @default(false)

  relatedCategoryId String?

  relatedCategory GlobalCategory? @relation(fields: [relatedCategoryId], references: [id], onDelete: SetNull)

  portfolioItems PortfolioItemTag[]

  createdAt DateTime @default(now())

  @@index([isFeatured, usageCount])
  @@index([relatedCategoryId])
}

/// Bundle of master services with a discount (31c). Master combines
/// e.g. manicure + pedicure into "Манипедикюр" with -15%. Final price
/// is computed on the fly from the contained services' prices, so we
/// don't denormalize it here.
model ServicePackage {
  id String @id @default(cuid())

  masterId String

  master Provider @relation("MasterServicePackages", fields: [masterId], references: [id], onDelete: Cascade)

  name String

  /// Reuses the existing `DiscountType` enum (PERCENT | FIXED). FIXED
  /// values are stored in kopeks (consistent with Service.price).
  discountType DiscountType @default(PERCENT)

  discountValue Int @default(0)

  isEnabled Boolean @default(true)

  sortOrder Int @default(0)

  items ServicePackageItem[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([masterId, sortOrder])
  @@index([masterId, isEnabled])
}

model ServicePackageItem {
  packageId String

  package ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  serviceId String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([packageId, serviceId])
  @@index([serviceId])
}
