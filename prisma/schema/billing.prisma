// === DOMAIN: Billing ===

model BillingPlan {
  id String @id @default(cuid())

  code String @unique

  name String

  tier PlanTier @default(FREE)

  scope SubscriptionScope @default(MASTER)

  features Json

  sortOrder Int @default(0)

  inheritsFromPlanId String?

  inheritsFromPlan BillingPlan? @relation("BillingPlanInherit", fields: [inheritsFromPlanId], references: [id])

  inheritedByPlans BillingPlan[] @relation("BillingPlanInherit")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  prices BillingPlanPrice[]

  subscriptions UserSubscription[]
}

model BillingPlanPrice {
  id String @id @default(cuid())

  planId String

  plan BillingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  periodMonths Int

  priceKopeks Int

  isActive Boolean @default(true)

  @@unique([planId, periodMonths])
  @@index([periodMonths])
}

model UserSubscription {
  id String @id @default(cuid())

  userId String

  planId String

  status SubscriptionStatus @default(ACTIVE)

  scope SubscriptionScope

  startedAt DateTime @default(now())

  currentPeriodStart DateTime?

  currentPeriodEnd DateTime?

  periodMonths Int @default(1)

  autoRenew Boolean @default(true)

  cancelAtPeriodEnd Boolean @default(false)

  cancelledAt DateTime?

  graceUntil DateTime?

  nextBillingAt DateTime?

  paymentMethodId String?

  lastPaymentAt DateTime?

  // Trial PREMIUM: 30-day onboarding gift for first-time master/studio profile.
  // Cron at /api/billing/renew/run downgrades the row in-place to FREE on expiry
  // (the @@unique([userId, scope]) constraint prevents creating a separate FREE
  // row alongside, so we mutate planId/isTrial/trialEndsAt and write to
  // BillingAuditLog for historical record).
  isTrial     Boolean   @default(false)
  trialEndsAt DateTime?

  // Set when the cron sends BILLING_TRIAL_ENDING_SOON notification, so we
  // never re-warn the same trial twice across cron runs.
  trialEndingNotificationSentAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan BillingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  payments BillingPayment[]

  @@unique([userId, scope])
  @@index([status, autoRenew, nextBillingAt])
  @@index([status, graceUntil])
  // Partial index on active trial rows only — cron needs fast lookup of
  // expiring/expired trials without scanning the whole subscriptions table.
  @@index([isTrial, trialEndsAt])
}

model BillingPayment {
  id String @id @default(cuid())

  subscriptionId String

  subscription UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  type String

  status BillingPaymentStatus

  amountKopeks Int

  currency String @default("RUB")

  periodMonths Int

  yookassaPaymentId String? @unique

  confirmationUrl String?

  idempotenceKey String @unique

  metadata Json?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([subscriptionId, status])
  @@index([status, createdAt])
}

model BillingAuditLog {
  id String @id @default(cuid())

  userId String

  scope SubscriptionScope?

  subscriptionId String?

  paymentId String?

  action String

  details Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

/// Daily snapshot of platform-wide MRR + active-subscription count.
/// Written by `/api/billing/mrr/snapshot/run` (external cron) once per
/// UTC day. Read by `admin/billing` KPI service to compute the
/// percent-change delta vs the same day-of-month a period ago.
///
/// `snapshotDate @db.Date` truncates to YYYY-MM-DD (one row per day);
/// the unique constraint guarantees idempotent re-runs. `mrrKopeks`
/// is `BigInt` to avoid Int32 overflow at scale (10 000 subs × 50 000
/// kopeks = 5×10^8, still inside Int32, but accumulates further with
/// growth — we sweep the risk off the table now).
///
/// `breakdownJson` reserved for future per-tier / per-scope splits;
/// currently null. When admin/billing adds drill-down ("MRR by
/// tier"), this field hydrates without a new migration.
model MrrSnapshot {
  id String @id @default(cuid())

  snapshotDate DateTime @unique @db.Date

  mrrKopeks BigInt

  activeSubscriptionsCount Int

  breakdownJson Json?

  createdAt DateTime @default(now())

  @@index([snapshotDate(sort: Desc)])
}
